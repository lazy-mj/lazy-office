/* =========================================================================
   ETRI 업무지원 플랫폼 — 공통 디자인 시스템 (shared/style.css)
   이 파일 하나를 고치면 모든 업무 자동화(전화요금/출장비/회의비 ...)에
   동일하게 반영됩니다. 업무별 스타일은 modules/<업무>/*.css 에만 작성하세요.
   ========================================================================= */
:root{
  --primary:#4F5FEA;
  --primary-dark:#3A46C4;
  --secondary:#EEF0FE;
  --bg:#F7F9FC;
  --card:#FFFFFF;
  --border:#D9E2EC;
  --danger:#D32F2F;
  --danger-bg:#FDECEC;
  --success:#2E7D32;
  --success-bg:#E9F5EA;
  --teal:#0F6E56;
  --teal-bg:#E1F5EE;
  --ink:#1D2733;
  --ink-soft:#5B6B7C;
  --mono:"SFMono-Regular",Consolas,"Liberation Mono",Menlo,monospace;
  --office-blue:#0B2F5C;
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  background:var(--bg);
  color:var(--ink);
  font-family:"Pretendard","Noto Sans KR",-apple-system,BlinkMacSystemFont,"Malgun Gothic",sans-serif;
  font-size:15.5px;
  line-height:1.6;
}
.shell{max-width:1160px;margin:0 auto;padding:32px 20px 96px;}

/* ---------- Header (공통) ---------- */
.app-header{
  position:relative; overflow:hidden;
  margin-bottom:22px; padding:24px 26px; border-radius:20px;
  background:linear-gradient(180deg, #eef4fb 0%, var(--bg) 100%);
  border:1px solid var(--border);
}
.app-header::before, .app-header::after{content:''; position:absolute; border-radius:50%; filter:blur(50px); z-index:0; pointer-events:none;}
.app-header::before{width:220px; height:220px; background:#0071e3; opacity:.16; top:-90px; left:-60px;}
.app-header::after{width:180px; height:180px; background:var(--office-blue); opacity:.10; top:-60px; right:10%;}
.app-header .title-row, .app-header .mascot-img{position:relative; z-index:1;}
.title-row{display:flex; align-items:center; justify-content:space-between; gap:24px;}
.title-text{flex-shrink:0;}
.title-line{display:flex; align-items:center; gap:10px; flex-wrap:wrap;}
.title-row h1{
  font-family:"Clash Display", -apple-system, "Apple SD Gothic Neo", "Pretendard", sans-serif;
  font-size:25px; font-weight:600; margin:0; color:var(--ink); letter-spacing:-0.02em;
  display:flex; align-items:center; gap:9px;
}
.title-icon{color:var(--office-blue); flex-shrink:0;}
.org-tag{
  font-size:12.5px; font-weight:700; color:var(--office-blue); background:#fff;
  padding:4px 12px; border-radius:999px; border:1px solid rgba(11,47,92,0.18);
}
.lock-note{
  position:relative; overflow:hidden; display:inline-flex; align-items:center; gap:6px;
  font-size:12.5px; color:var(--primary); font-weight:600; margin:10px 0 0;
  background:rgba(255,255,255,0.6); backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px);
  border:1px solid rgba(255,255,255,0.7); padding:6px 14px; border-radius:999px;
  box-shadow:0 3px 10px rgba(0,0,0,0.04), inset 0 1px 0 rgba(255,255,255,0.7);
}
.lock-note::after{
  content:''; position:absolute; top:0; left:-160%; width:55%; height:100%;
  background:linear-gradient(115deg, transparent 20%, rgba(255,255,255,0.8) 50%, transparent 80%);
  animation:lock-note-shimmer 4.6s ease-in-out infinite;
}
.mascot-img{height:104px; width:auto; flex-shrink:0;}

/* ---------- 개별 업무 도구용 히어로 (허브 홈 전용 .hero와는 별개 이름) ----------
   .shell(max-width 컨테이너) 밖, site-header-placeholder 바로 다음에 위치해야
   허브 홈처럼 화면 전체 폭으로 꽉 차게 보입니다. */
.tool-hero{
  position:relative; overflow:visible; text-align:center;
  padding:56px 24px 44px;
  background:#fff;
  border-bottom:none;
}
.tool-hero::before{
  content:''; position:absolute; left:50%; top:-30px; transform:translateX(-50%);
  width:360px; height:360px; border-radius:50%; z-index:0; pointer-events:none;
  filter:blur(55px); opacity:.45;
  background:
    radial-gradient(circle at 30% 35%, #4F7FFF 0%, transparent 30%),
    radial-gradient(circle at 65% 30%, #8B5CF6 0%, transparent 30%),
    radial-gradient(circle at 60% 65%, #EA5FD1 0%, transparent 30%),
    radial-gradient(circle at 35% 65%, #4FC3F7 0%, transparent 30%);
}
.tool-hero-inner{position:relative; z-index:1;}
.tool-icon-badge{
  position:relative; overflow:hidden; width:58px; height:58px; border-radius:16px; margin:0 auto 18px;
  display:flex; align-items:center; justify-content:center;
  background:linear-gradient(135deg, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0.25) 100%);
  backdrop-filter:blur(14px) saturate(160%); -webkit-backdrop-filter:blur(14px) saturate(160%);
  border:1px solid rgba(255,255,255,0.7);
  box-shadow:0 8px 22px rgba(11,47,92,0.18), inset 0 1px 0 rgba(255,255,255,0.85), inset 0 -6px 12px rgba(11,47,92,0.08);
}
.tool-icon-badge img{width:30px; height:30px; object-fit:contain;}
.tool-hero-icon{width:64px; height:auto; margin:0 auto 16px; display:block; filter:drop-shadow(0 8px 16px rgba(11,47,92,0.22));}
.tool-hero h1{
  font-family:"Clash Display", -apple-system, "Apple SD Gothic Neo", "Pretendard", sans-serif;
  font-size:32px; font-weight:700; letter-spacing:-0.02em; margin:0 0 10px; color:#000;
}
.tool-tagline{font-size:14.5px; color:#3D4A58; margin:0 0 18px;}
/* .tool-hero 안에서만 쓰는 유리질감 lock-note (기본 .lock-note는 그대로 유지) */
.tool-hero .lock-note{
  margin:0; background:rgba(255,255,255,0.28); border-color:rgba(255,255,255,0.55);
  color:#4F5FEA; padding:5px 12px;
}
.tool-hero .lock-note .icon-svg{color:#4F5FEA;}

/* ---------- Platform Nav (공통, 업무 전환용) ---------- */
.platform-nav{display:flex; align-items:center; gap:6px; margin:0 0 18px; flex-wrap:wrap;}
.platform-nav a{
  font-size:13px; font-weight:700; color:var(--ink-soft); text-decoration:none;
  padding:7px 12px; border-radius:8px;
}
.platform-nav a:hover{background:var(--secondary); color:var(--primary);}
.platform-nav a.current{background:var(--primary); color:#fff;}

/* ---------- Stepper (미니멀 라인 — 박스/테두리 없이 원형 뱃지+라벨만) ---------- */
.stepper{
  list-style:none; display:flex; align-items:center; justify-content:center; gap:0; padding:4px 0; margin:0 0 24px; flex-wrap:wrap;
}
.stepper .step{display:flex; align-items:center; gap:9px; color:var(--ink-soft); font-weight:600; font-size:13.5px; padding:4px 2px;}
.stepper .dot{
  width:26px; height:26px; border-radius:50%; background:#EEF1F5; color:var(--ink-soft);
  display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:800; flex-shrink:0;
  transition:all .2s;
}
.stepper .step.current .dot{
  background:linear-gradient(135deg, #4F7FFF 0%, #8B5CF6 60%, #EA5FD1 130%);
  color:#fff; box-shadow:0 0 0 5px rgba(79,95,234,0.12), 0 4px 10px rgba(79,95,234,0.35);
}
.stepper .step.current .label{color:var(--primary); font-weight:800;}
.stepper .step.done .dot{background:var(--teal); color:#fff;}
.stepper .step.done .label{color:var(--teal);}
.stepper .connector{width:34px; height:1.5px; background:var(--border); margin:0 12px; flex-shrink:0;}
.stepper .connector.done{background:var(--teal);}
.stepper .arrow{color:var(--border); font-size:16px;}

/* ---------- Card ---------- */
.card{
  background:var(--card); border:1px solid #D3D9E3; border-radius:18px;
  padding:26px; margin-bottom:22px; box-shadow:0 6px 18px rgba(20,30,60,0.07), 0 1px 4px rgba(20,30,60,0.04);
}
.card-warn{
  border-left:none;
  background:linear-gradient(135deg, rgba(220,61,61,.07) 0%, rgba(220,61,61,.015) 45%, #fff 80%);
  border-color:#F3D5D5;
}
.card-head{margin-bottom:20px;}
.card-head h2{
  font-size:22px; margin:0 0 8px; color:var(--ink); font-weight:800;
  display:flex; align-items:center; gap:12px; letter-spacing:-0.01em;
}
.step-badge{
  display:inline-flex; align-items:center; justify-content:center;
  width:34px; height:34px; border-radius:50%; flex-shrink:0;
  background:var(--primary); color:#fff; font-size:17px; font-weight:800;
}
.step-badge svg{width:18px; height:18px; flex-shrink:0;} /* 크기 지정 누락 시 안전장치 */
.step-badge-warn{background:var(--danger);}
.card-head .desc{font-size:13.5px; color:var(--ink-soft); margin:0;}

/* ---------- Buttons ---------- */
.toolbar{display:flex; gap:10px; flex-wrap:wrap; margin-bottom:16px;}
.btn{
  font-family:inherit; font-size:14.5px; font-weight:700; padding:12px 20px; border-radius:10px;
  border:1px solid transparent; cursor:pointer; display:inline-flex; align-items:center; justify-content:center; gap:6px;
  transition:filter .12s, transform .05s;
}
.btn:active{transform:translateY(1px);}
.btn:focus-visible{outline:2px solid var(--primary); outline-offset:2px;}
.btn-primary{background:var(--primary); color:#fff;}
.btn-primary:hover{filter:brightness(1.06);}
.btn-primary:disabled{background:#B9CCE0; cursor:not-allowed;}
.btn-lg{padding:14px 26px; font-size:15.5px;}
.btn-outline{background:#fff; color:var(--primary); border-color:var(--primary);}
.btn-outline:hover{background:var(--secondary);}
.btn-danger-outline{background:#fff; color:var(--danger); border-color:var(--danger);}
.btn-danger-outline:hover{background:var(--danger-bg);}
.btn-danger{background:var(--danger); color:#fff;}
.btn-danger:hover{filter:brightness(1.08);}

/* ---------- 주요 실행 버튼 (검증 실행/분할 실행 등) — 글래스모피즘 + 메쉬 그라데이션 + 플로팅 + 은은한 반짝임 ---------- */
.btn-action{
  position:relative; isolation:isolate; overflow:hidden; border:none; border-radius:14px;
  padding:13px 28px; font-size:15px; font-weight:800; color:#fff; cursor:pointer;
  letter-spacing:-0.01em; font-family:inherit;
  -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; text-rendering:optimizeLegibility;
  text-shadow:0 1px 1px rgba(0,0,0,0.06);
  display:inline-flex; align-items:center; gap:8px;
  background:
    radial-gradient(120% 160% at 12% 15%, rgba(79,127,255,.62) 0%, transparent 55%),
    radial-gradient(120% 160% at 88% 20%, rgba(139,92,246,.58) 0%, transparent 55%),
    radial-gradient(130% 170% at 55% 105%, rgba(234,95,209,.5) 0%, transparent 60%),
    linear-gradient(135deg, rgba(79,95,234,.72) 0%, rgba(58,70,196,.72) 100%);
  backdrop-filter:blur(14px) saturate(160%); -webkit-backdrop-filter:blur(14px) saturate(160%);
  border:1px solid rgba(255,255,255,0.4);
  box-shadow:0 16px 30px rgba(79,95,234,0.28), 0 4px 10px rgba(79,95,234,0.18), inset 0 1px 0 rgba(255,255,255,0.45), inset 0 0 0 1px rgba(255,255,255,0.08);
  transition:transform .18s ease, box-shadow .18s ease;
}
.btn-action::before{
  content:''; position:absolute; inset:0; z-index:1;
  background:linear-gradient(120deg, rgba(255,255,255,.45) 0%, rgba(255,255,255,0) 40%);
  mix-blend-mode:overlay; pointer-events:none;
}
.btn-action::after{
  content:''; position:absolute; top:0; left:8%; right:8%; height:1px; background:rgba(255,255,255,.6); pointer-events:none;
}
.btn-action .shine{
  content:''; position:absolute; top:-70%; left:-40%; width:55%; height:240%; z-index:1;
  background:linear-gradient(75deg, rgba(255,255,255,0) 0%, rgba(255,255,255,.45) 50%, rgba(255,255,255,0) 100%);
  transform:rotate(8deg); filter:blur(10px);
  animation:btn-shine 4.8s ease-in-out infinite; pointer-events:none;
}
@keyframes btn-shine{
  0%{left:-45%;}
  45%{left:110%;}
  100%{left:110%;}
}
.btn-action span{position:relative; z-index:2;}
.btn-action:hover:not(:disabled){transform:translateY(-3px); box-shadow:0 22px 36px rgba(79,95,234,0.34), 0 6px 14px rgba(79,95,234,0.22), inset 0 1px 0 rgba(255,255,255,0.5);}
.btn-action:active:not(:disabled){transform:translateY(-1px);}
.btn-action:disabled{
  background:linear-gradient(135deg, rgba(225,230,245,.75) 0%, rgba(236,231,248,.75) 100%);
  color:#A7B0C4; cursor:not-allowed; backdrop-filter:blur(8px);
  box-shadow:0 4px 12px rgba(20,30,60,0.05), inset 0 1px 0 rgba(255,255,255,.6);
  text-shadow:none;
}
.btn-action:disabled::before, .btn-action:disabled::after, .btn-action:disabled .shine{display:none;}

/* ---------- 버튼 툴팁 (라이트 글래스모피즘) ---------- */
[data-tooltip]{position:relative;}
[data-tooltip]::after{
  content:attr(data-tooltip);
  position:absolute; bottom:calc(100% + 12px); left:50%;
  transform:translateX(-50%) translateY(4px);
  background:rgba(255,255,255,0.85); backdrop-filter:blur(12px) saturate(160%); -webkit-backdrop-filter:blur(12px) saturate(160%);
  color:var(--ink); font-size:12px; font-weight:600; line-height:1.5;
  padding:9px 13px; border-radius:10px; width:max-content; max-width:220px; text-align:center;
  white-space:pre-line; border:1px solid rgba(255,255,255,0.7);
  opacity:0; pointer-events:none; z-index:60;
  transition:opacity .18s ease, transform .18s ease;
  box-shadow:0 12px 26px rgba(20,30,60,0.16), 0 3px 8px rgba(20,30,60,0.08), inset 0 1px 0 rgba(255,255,255,0.8);
}
[data-tooltip]::before{
  content:''; position:absolute; bottom:calc(100% + 8px); left:50%;
  transform:translateX(-50%) translateY(4px) rotate(45deg);
  width:9px; height:9px; background:rgba(255,255,255,0.85);
  border-right:1px solid rgba(255,255,255,0.7); border-bottom:1px solid rgba(255,255,255,0.7);
  opacity:0; pointer-events:none; z-index:59; transition:opacity .18s ease, transform .18s ease;
}
[data-tooltip]:hover::after{opacity:1; transform:translateX(-50%) translateY(0);}
[data-tooltip]:hover::before{opacity:1; transform:translateX(-50%) translateY(0) rotate(45deg);}

/* ---------- 확인 모달 (native confirm() 대체, AppCore.dialog.confirm) ---------- */
.modal-overlay{
  position:fixed; inset:0; background:rgba(16,24,40,0.45);
  display:flex; align-items:center; justify-content:center; z-index:200;
  opacity:0; transition:opacity .18s ease; padding:20px;
}
.modal-overlay.show{opacity:1;}
.modal-box{
  background:var(--card); border-radius:14px; padding:26px;
  width:100%; max-width:380px; box-shadow:0 20px 50px rgba(16,24,40,0.25);
  transform:translateY(10px) scale(.98); transition:transform .18s ease;
  text-align:center;
}
.modal-overlay.show .modal-box{transform:translateY(0) scale(1);}
.modal-title{font-size:17px; font-weight:800; color:var(--ink); margin-bottom:8px;}
.modal-message{font-size:13.5px; color:var(--ink-soft); line-height:1.6; margin-bottom:22px;}
.modal-message ul{text-align:left; margin:0; padding-left:18px;}
.modal-message li{margin-bottom:8px;}
.modal-message li:last-child{margin-bottom:0;}
.modal-icon{width:38px; height:38px; border-radius:50%; margin:0 auto 12px; display:flex; align-items:center; justify-content:center;}
.modal-icon-warning{background:var(--danger-bg); color:var(--danger);}
.modal-actions{display:flex; justify-content:center; gap:10px;}
.modal-actions .btn{padding:10px 18px; font-size:13.5px; flex:1;}
.modal-actions.stacked{flex-direction:column;}
.modal-actions.stacked .btn{flex:none; width:100%;}

/* ---------- Dropzone ---------- */
.dropzone{
  border:2px dashed var(--border); border-radius:12px; background:#FBFCFE;
  padding:22px; text-align:center; cursor:pointer; margin-bottom:16px; transition:border-color .15s, background .15s;
}
.dropzone:hover, .dropzone.drag-over{border-color:var(--primary); background:var(--secondary);}
.dropzone-inner{display:flex; flex-direction:column; align-items:center; gap:6px;}
.dz-icon{color:var(--ink-soft); display:inline-flex;}
.dz-text{font-size:14px; color:var(--ink);}
.dz-hint{font-size:12px; color:var(--ink-soft);}

/* ---------- Form bits ---------- */
.row-between{display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap; margin-bottom:14px;}
.checkbox-label{font-size:13.5px; color:var(--ink-soft); display:flex; align-items:center; gap:6px;}
.search-box{position:relative;}
.search-icon{position:absolute; left:12px; top:50%; transform:translateY(-50%); font-size:13px; color:var(--ink-soft); pointer-events:none;}
input[type=text]{
  font-family:inherit; font-size:14px; padding:10px 12px; border:1px solid var(--border);
  border-radius:8px; background:#fff; color:var(--ink);
}
.search-box input[type=text]{padding-left:36px;}
.sheet-select{
  font-family:inherit; font-size:14px; padding:9px 12px; border:1px solid var(--border);
  border-radius:8px; margin-bottom:12px; background:#fff;
}
.memo-field{display:flex; flex-direction:column; gap:4px;}
.memo-field label{font-size:12.5px; color:var(--ink-soft); font-weight:600;}
.memo-field input{width:200px;}
.output-fields{display:flex; gap:16px; flex-wrap:wrap;}

/* ---------- Progress steps (버튼처럼 보이지 않는 상태 표시) ---------- */
.progress{list-style:none; display:flex; justify-content:center; padding:18px 4px 4px; margin:16px 0 32px;}
.progress li{
  flex:0 0 110px; display:flex; flex-direction:column; align-items:center; gap:7px;
  font-size:12px; font-weight:600; color:var(--ink-soft); position:relative;
}
.progress li:not(:last-child)::after{
  content:''; position:absolute; top:11px; left:calc(50% + 16px); width:calc(110px - 32px);
  height:2px; background:var(--border); z-index:0; transition:background .3s ease;
}
.progress li.complete:not(:last-child)::after{background:var(--teal);}
.progress .dot{
  width:22px; height:22px; border-radius:50%; flex-shrink:0;
  background:#fff; border:2px solid var(--border); color:var(--ink-soft);
  display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700;
  position:relative; z-index:1; transition:background .25s ease, border-color .25s ease, color .25s ease;
}
.progress li.active .dot{
  border-color:var(--primary); background:var(--primary); color:#fff;
  animation:progress-pulse 1.4s ease-in-out infinite;
}
.progress li.complete .dot{
  border-color:var(--teal); background:var(--teal); color:#fff; font-size:0;
}
.progress li.complete .dot::after{content:'✓'; font-size:12px;}
.progress li.active .label{color:var(--primary); font-weight:800;}
.progress li.complete .label{color:var(--teal);}
@keyframes progress-pulse{
  0%,100%{box-shadow:0 0 0 0 rgba(0,91,172,0.32);}
  50%{box-shadow:0 0 0 6px rgba(0,91,172,0);}
}

/* ---------- Table ---------- */
.table-wrap{max-height:440px; overflow:auto; border:1px solid var(--border); border-radius:10px;}
table{width:100%; border-collapse:collapse; font-size:13.5px; min-width:560px;}
th,td{border:1px solid var(--border); padding:9px 10px; text-align:center;}
th{background:#F1F5FA; font-weight:700; font-size:12.5px; color:var(--ink); position:sticky; top:0;}
table th[data-sort]{cursor:pointer; user-select:none;}
table th[data-sort]:hover{background:var(--secondary);}
td.num{text-align:right; font-family:var(--mono);}
td input{width:100%; border:1px solid transparent; background:transparent; text-align:center; font-family:inherit; font-size:13.5px; padding:4px;}
td input:focus{border-color:var(--primary); background:#fff; outline:none;}
.hint{font-size:12px; color:var(--ink-soft); margin:8px 0 18px;}
code{background:#EEF1F5; padding:1px 6px; border-radius:5px; font-size:12px;}

/* ---------- Stat cards (카드 안의 카드라 그림자는 넣지 않음) ---------- */
.stat-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:18px;}
.stat-grid .card-mini{
  background:linear-gradient(135deg, rgba(79,95,234,.07) 0%, rgba(79,95,234,.015) 65%);
  border:1px solid var(--border); border-radius:14px; padding:18px;
}
.stat-grid .card-mini.warn{
  background:linear-gradient(135deg, rgba(220,61,61,.09) 0%, rgba(220,61,61,.015) 65%);
  border-color:#F3D5D5;
}
.stat-grid .n{font-size:25px; font-weight:800; color:var(--primary); font-family:var(--mono); letter-spacing:-0.01em;}
.stat-grid .card-mini.warn .n{color:var(--danger);}
.stat-grid .l{font-size:13px; color:var(--ink-soft); margin-top:7px; font-weight:700;}

/* ---------- 상태 뱃지(Badge) ---------- */
.status-pill{display:inline-block; padding:3px 10px; border-radius:20px; font-size:12px; font-weight:700;}
.status-pill.ok{background:var(--success-bg); color:var(--success);}
.status-pill.mismatch{background:var(--danger-bg); color:var(--danger);}
.status-pill.unknown{background:#EEF1F5; color:var(--ink-soft);}
tr.row-mismatch td{background:var(--danger-bg);}

/* ---------- Status / error banners ---------- */
.status{font-size:13px; padding:10px 14px; border-radius:8px; margin:0 0 14px; font-weight:600; text-align:center;}
.status.ok{background:var(--teal-bg); color:var(--teal);}
.status.warn{background:var(--danger-bg); color:var(--danger);}
.error-banner{
  background:var(--danger-bg); border:1px solid #f5c6c6; color:#8a2323; border-radius:10px;
  padding:12px 16px; margin-bottom:16px; font-size:13.5px; display:flex; justify-content:space-between; gap:12px;
}
.error-banner button{background:none; border:none; color:#8a2323; font-weight:700; cursor:pointer; font-size:14px;}

/* ---------- Toast (하단 중앙, 라이트 글래스모피즘 + 아이콘 배지로 상태 구분) ---------- */
.toast-zone{
  position:fixed; bottom:22px; left:0; right:0; display:flex; flex-direction:column; align-items:center; gap:8px;
  z-index:999; pointer-events:none; max-width:calc(100vw - 36px);
}
.toast{
  display:inline-flex; align-items:center; gap:10px; pointer-events:auto;
  background:rgba(255,255,255,0.75); backdrop-filter:blur(14px) saturate(160%); -webkit-backdrop-filter:blur(14px) saturate(160%);
  color:var(--ink); padding:11px 20px 11px 16px; border-radius:999px; font-size:13.5px; font-weight:700;
  box-shadow:0 14px 30px rgba(20,30,60,0.14), 0 4px 10px rgba(20,30,60,0.08), inset 0 1px 0 rgba(255,255,255,0.7);
  border:1px solid rgba(255,255,255,0.6);
  opacity:0; transform:translateY(14px) scale(.96);
  transition:opacity .32s cubic-bezier(.22,.9,.35,1), transform .32s cubic-bezier(.22,.9,.35,1);
}
.toast.show{opacity:1; transform:translateY(0) scale(1);}
.toast .dot-icon{
  width:20px; height:20px; border-radius:50%; flex-shrink:0; display:flex; align-items:center; justify-content:center;
  background:linear-gradient(135deg, #4F7FFF, #8B5CF6);
  box-shadow:0 2px 6px rgba(20,30,60,0.18);
}
.toast .dot-icon svg{width:12px; height:12px; stroke:#fff; fill:none; stroke-width:2.5; stroke-linecap:round; stroke-linejoin:round;}
.toast.success .dot-icon{background:linear-gradient(135deg,#22C55E,#16A34A);}
.toast.error .dot-icon{background:linear-gradient(135deg,#F97373,#DC3D3D);}

/* ---------- Readme / footer ---------- */
.foot-note{font-size:12px; color:var(--ink-soft); margin-top:20px; border-top:1px dashed var(--border); padding-top:14px; text-align:center; line-height:1.7;}
.repo-link{display:inline-flex; align-items:center; gap:6px; color:var(--primary); font-weight:700; text-decoration:none;}
.repo-link:hover{text-decoration:underline;}
.repo-link .icon-svg{width:15px; height:15px; flex-shrink:0;}

/* 개별 도구 푸터 하단 줄: 문의처 + 저장소 링크를 허브 푸터처럼 가운데 정렬, 병렬 배치 */
.foot-links{display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:10px; margin-top:12px; font-size:13px;}
.foot-links .divider{width:3px; height:3px; border-radius:50%; background:var(--ink-soft); opacity:.5; flex-shrink:0;}
.foot-links .repo-link{margin-top:0;}
.foot-contact{display:inline-flex; align-items:center; gap:6px; color:var(--ink-soft); font-weight:600;}
.foot-contact .icon-svg{width:14px; height:14px; flex-shrink:0;}

/* ---------- 사이트 공통 헤더: 글래스모피즘 스티키 (좌측 브랜드 + 우측 탭) ---------- */
/* JS가 실제 헤더를 넣기 전, 이 자리만큼 미리 공간을 잡아둬서 삽입 시 화면이
   덜컹거리거나 "헤더 없는 화면"이 잠깐 스치는 걸 방지함 (header.js가 이 자리를
   실제 헤더로 교체함) */
.site-header-placeholder{height:52px;}

.site-header{
  position:sticky; top:0; z-index:50;
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 28px;
  background:rgba(255,255,255,0.55);
  backdrop-filter:blur(16px) saturate(160%); -webkit-backdrop-filter:blur(16px) saturate(160%);
  border-bottom:1px solid rgba(220,223,227,0.6);
}
.site-header .brand{
  font-family:"Clash Display", -apple-system, "Apple SD Gothic Neo", "Pretendard", sans-serif;
  font-size:19px; letter-spacing:-0.02em; text-decoration:none; display:flex; align-items:center; gap:8px;
  color:#000;
}
.site-header .brand .brand-mark{width:18px; height:18px; flex-shrink:0; display:block;}
.site-header .brand .brand-text{display:flex; align-items:center;}
.site-header .brand .lazy{color:#000; font-weight:600;}
.site-header .brand .office{color:#000; font-weight:700;}

.site-header nav.desktop-nav{display:flex; gap:2px;}
.site-header nav a{
  font-size:13.5px; font-weight:600; color:var(--ink-soft); text-decoration:none;
  padding:8px 14px; border-radius:999px; transition:background .15s, color .15s;
}
.site-header nav a:hover{background:rgba(11,47,92,0.06); color:var(--office-blue);}
.site-header nav a.active{color:var(--office-blue); background:none;}

.hamburger-btn{display:none; background:none; border:none; cursor:pointer; padding:6px; color:var(--ink);}
.hamburger-btn .icon-svg{width:22px; height:22px;}

.mobile-nav{
  display:none; position:fixed; top:52px; left:0; right:0; z-index:49;
  background:rgba(255,255,255,0.85); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border); padding:8px; flex-direction:column; gap:2px;
}
.mobile-nav.open{display:flex;}
.mobile-nav a{font-size:14.5px; font-weight:600; color:var(--ink-soft); text-decoration:none; padding:12px 16px; border-radius:999px;}
.mobile-nav a.active{color:var(--office-blue); background:none;}
.mobile-nav a:hover{background:rgba(11,47,92,0.06);}

@media (max-width: 640px){
  .site-header nav.desktop-nav{display:none;}
  .hamburger-btn{display:inline-flex;}
}

/* ---------- 플랫폼 홈(업무 선택) 전용: 히어로 ---------- */
.icon-svg{stroke:currentColor; fill:none; stroke-width:2; stroke-linecap:round; stroke-linejoin:round; display:block;}

.hero{
  position:relative; overflow:visible;
  background:#fff;
  border-bottom:none;
  padding:88px 24px 104px; text-align:center;
}
.hero::before{
  content:""; position:absolute; left:50%; top:-40px; transform:translateX(-50%);
  width:460px; height:460px; border-radius:50%; z-index:0; display:block;
  filter:blur(70px); opacity:.45;
  background:
    radial-gradient(circle at 30% 35%, #4F7FFF 0%, transparent 30%),
    radial-gradient(circle at 65% 30%, #8B5CF6 0%, transparent 30%),
    radial-gradient(circle at 60% 65%, #EA5FD1 0%, transparent 30%),
    radial-gradient(circle at 35% 65%, #4FC3F7 0%, transparent 30%);
}
.hero-inner{position:relative; z-index:1; animation:page-reveal .9s cubic-bezier(.22,.9,.35,1) both;}

@keyframes page-reveal{
  from{ opacity:0; filter:blur(14px); transform:translateY(8px) scale(1.01); }
  to{ opacity:1; filter:blur(0); transform:translateY(0) scale(1); }
}
.site-header{animation:page-reveal .7s cubic-bezier(.22,.9,.35,1) both;}

/* Clash Display(Fontshare) 워드마크 - 로드 실패 시 자동으로 다음 폰트로 폴백됨 */
.wordmark{
  font-family:"Clash Display", -apple-system, "Apple SD Gothic Neo", "Pretendard", sans-serif;
  font-size:clamp(42px, 7vw, 68px); font-weight:600; letter-spacing:-0.035em; margin:0 0 34px; line-height:1.0;
}
.wordmark .lazy{color:#000; font-weight:600;}
.wordmark .office{color:#000; font-weight:700;}
.hero p{font-size:15.5px; color:#3D4A58; margin:0 auto 20px; max-width:440px;}

/* 히어로 트러스트 뱃지 3종을 한 줄로 배치하는 wrapper. 개별 .lock-note 필 버튼 디자인 자체는 변경하지 않음 */
.trust-badges{display:flex; align-items:center; justify-content:center; flex-wrap:wrap; gap:8px;}

/* .hero 안에서만 적용되는 유리질감 lock-note (다른 페이지의 기본 .lock-note는 그대로 유지됨) */
.hero .lock-note{
  position:relative; overflow:hidden;
  display:inline-flex; align-items:center; gap:5px; font-size:12.5px; color:#4F5FEA; font-weight:600; margin:0;
  background:rgba(255,255,255,0.28); backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px);
  border:1px solid rgba(255,255,255,0.55); padding:5px 9px; border-radius:999px;
  box-shadow:0 4px 14px rgba(0,0,0,0.05), inset 0 1px 0 rgba(255,255,255,0.7);
}
.hero .lock-note::after{
  content:''; position:absolute; top:0; left:-160%; width:55%; height:100%;
  background:linear-gradient(115deg, transparent 20%, rgba(255,255,255,0.75) 50%, transparent 80%);
  animation:lock-note-shimmer 4.2s ease-in-out infinite;
}
@keyframes lock-note-shimmer{
  0%{left:-160%;}
  55%{left:160%;}
  100%{left:160%;}
}
.hero .lock-note .icon-svg{width:14px; height:14px; flex-shrink:0; position:relative; z-index:1; color:#4F5FEA;}

/* 홈 허브 화면 전용: 히어로가 풀 화이트 배경을 쓰므로 body도 맞춤 (다른 도구 페이지엔 영향 없음) */
body.home-page{background:#fff;}
/* 개별 도구 페이지(전화요금/예산검증)도 tool-hero가 풀 화이트 배경을 쓰므로 동일하게 맞춤 */
body.tool-page{background:#fff;}

/* ---------- 플랫폼 홈 전용: 카드 ---------- */
.content{max-width:900px; margin:-56px auto 0; padding:0 24px 60px; position:relative; z-index:2; animation:page-reveal 1s cubic-bezier(.22,.9,.35,1) .12s both;}
.section-label{font-size:12.5px; font-weight:700; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.05em; margin:0 0 14px 4px;}
.module-grid{display:grid; grid-template-columns:repeat(auto-fill,minmax(230px,1fr)); gap:20px;}

.module-card{
  background:var(--card); border:1px solid #D3D9E3; border-radius:18px; padding:22px;
  box-shadow:0 10px 24px rgba(20,30,60,0.10), 0 2px 8px rgba(20,30,60,0.06);
  text-decoration:none; color:var(--ink); display:flex; flex-direction:column; gap:8px;
  transition:box-shadow .18s ease, transform .15s ease, border-color .15s ease;
  cursor:pointer;
}
.module-card:hover{box-shadow:0 18px 36px rgba(20,30,60,0.16), 0 4px 10px rgba(20,30,60,0.08); transform:translateY(-4px); border-color:#D3D9E3;}

.module-card .icon{
  width:44px; height:44px; border-radius:12px; margin-bottom:10px;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;
}
.module-card .icon .icon-svg{width:22px; height:22px;}
.module-card.c-navy .icon{background:#E8ECFE; color:#4F5FEA;}
.module-card.c-terracotta .icon{background:#FCE9FA; color:#C13FC0;}

.module-card h3{font-size:15.5px; margin:0; font-weight:600; letter-spacing:-0.01em; -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale;}
.module-card .roadmap-line{display:flex; align-items:center; gap:5px; font-size:11px; color:#9AA6B2; margin-top:-2px;}
.module-card .roadmap-line .dot{width:5px; height:5px; border-radius:50%; background:#C9D2DC; flex-shrink:0;}
.module-card p{font-size:12.5px; font-weight:400; color:#9AA6B2; margin:0;}

/* "바로가기" 필버튼 - 항상 보이는 작고 납작한 형태 */
.cta-wrap{display:block; margin-top:2px;}
.module-card .cta{
  font-size:11.5px; font-weight:600; color:var(--ink); background:#fff; border:1px solid var(--border);
  padding:5px 11px; border-radius:999px; display:inline-flex; align-items:center; gap:4px; opacity:1;
}
.module-card .cta .icon-svg{width:10px; height:10px;}

/* "다음 자동화 제안" 카드 - 회색/하늘색 톤, 클릭 불가 */
.module-card.suggest{border:1.5px dashed #cfd9e0; background:linear-gradient(180deg, #f4f8fb 0%, #eef2f5 100%); cursor:default; box-shadow:none;}
.module-card.suggest:hover{transform:none; box-shadow:none; border-color:#b9c7d1;}
.module-card.suggest .icon{background:#fff; color:#5B6B7C;}
.module-card.suggest h3{color:#4a5a68;}
.module-card.suggest p{color:#7c8b98;}
.module-card.suggest .suggest-contact{margin-top:2px; font-size:11.5px; font-weight:600; color:#5f7488;}

.content .foot-note{margin-top:32px;}

/* 허브 전용 푸터 - 가운데 정렬, 저작권 + GitHub 저장소 링크 */
.hub-footer{
  display:flex; align-items:center; justify-content:center; gap:10px;
  margin:40px auto 0; padding-top:22px; border-top:1px dashed var(--border);
}
.hub-footer p, .hub-footer span, .hub-footer a{margin:0; line-height:1;}
.hub-footer .copyright{font-size:12px; color:var(--ink-soft);}
.hub-footer .divider{width:3px; height:3px; border-radius:50%; background:var(--ink-soft); opacity:.5; flex-shrink:0; align-self:center;}
.hub-footer .repo-link{
  display:inline-flex; align-items:center; gap:6px; font-size:12.5px; font-weight:700;
  color:var(--ink-soft); text-decoration:none;
}
.hub-footer .repo-link:hover{color:var(--office-blue);}
.hub-footer .repo-link .icon-svg{width:15px; height:15px; fill:currentColor; stroke:none; flex-shrink:0;}

/* =========================================================================
   반응형 (모바일) — 이 블록만 고치면 모든 업무 화면에 동일하게 적용됩니다.
   ========================================================================= */
@media (max-width: 768px){
  .shell{padding:20px 14px 72px;}
  .title-row{flex-direction:column; align-items:flex-start; gap:12px;}
  .mascot-img{height:64px; align-self:flex-end;}
  .title-row h1{font-size:20px;}
  .stepper{padding:12px; gap:4px;}
  .stepper .label{display:none;} /* 모바일에서는 점(dot)만 표시해 줄바꿈 방지 */
  .card{padding:18px;}
  .toolbar{flex-direction:column;}
  .toolbar .btn{width:100%; justify-content:center;}
  .row-between{flex-direction:column; align-items:stretch;}
  .output-fields{flex-direction:column;}
  .memo-field input{width:100%;}
  .stat-grid{grid-template-columns:repeat(2,1fr);}
  table{min-width:520px;} /* 표는 가로 스크롤 유지 */
  .module-grid{grid-template-columns:1fr;}
  .hero{padding:56px 20px 76px;}
  .content{margin-top:-40px;}
}
@media (max-width: 420px){
  .stat-grid{grid-template-columns:1fr;}
}
